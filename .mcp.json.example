{
  "mcpServers": {
    "notebooklm": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "notebooklm-mcp@latest"]
    },
    "pcc-api": {
      "command": "node",
      "args": ["__PROJECT_DIR__\\pcc-api-mcp\\dist\\index.js"]
    },
    "smugmug": {
      "command": "node",
      "args": ["__PROJECT_DIR__\\smugmug-mcp\\dist\\index.js"],
      "env": {
        "SMUGMUG_API_KEY": "__SMUGMUG_API_KEY__",
        "SMUGMUG_API_SECRET": "__SMUGMUG_API_SECRET__",
        "SMUGMUG_ACCESS_TOKEN": "__SMUGMUG_ACCESS_TOKEN__",
        "SMUGMUG_TOKEN_SECRET": "__SMUGMUG_TOKEN_SECRET__"
      }
    }
  }
}
