# 全能標案助理 — Staging 環境配置
#
# Staging 環境用途：
# - 整合測試、QA 驗收
# - 接近生產的配置
# - 真實 OAuth、真實資料庫
# - 不使用 mock 資料
#
# 時間戳：2026-02-23

# ────────────────────────────────────────────────────────────
# 應用程式設定
# ────────────────────────────────────────────────────────────

NEXT_PUBLIC_APP_ENV=staging
NEXT_PUBLIC_APP_URL=https://staging.bidding-assistant.example.com
NODE_ENV=production

# ────────────────────────────────────────────────────────────
# Supabase 設定（Staging 環境）
# ────────────────────────────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=https://staging-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...staging...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...staging-secret...
NEXT_PUBLIC_TENANT_ID=staging-tenant

DB_ENFORCE_RLS=true
DB_POOL_SIZE=20
DB_QUERY_TIMEOUT=5000

# ────────────────────────────────────────────────────────────
# NextAuth 配置
# ────────────────────────────────────────────────────────────

# OpenSSL 生成：openssl rand -base64 32
NEXTAUTH_SECRET=your-staging-nextauth-secret-min-32-chars
NEXTAUTH_URL=https://staging.bidding-assistant.example.com

# Google OAuth（測試用帳號）
GOOGLE_CLIENT_ID=your-google-client-id-staging.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-secret-staging

# ────────────────────────────────────────────────────────────
# 外部 API（Staging）
# ────────────────────────────────────────────────────────────

NOTION_API_TOKEN=ntn_staging_token_here
NOTION_DATABASE_ID=staging-database-id

ANTHROPIC_API_KEY=sk-ant-staging-api-key
PCC_API_BASE_URL=https://api.pcc.gov.tw

# ────────────────────────────────────────────────────────────
# 功能開關（Staging）
# ────────────────────────────────────────────────────────────

DEBUG=false
NEXT_PUBLIC_USE_MOCK_DATA=false
NOTION_SYNC_INTERVAL=1800
ENABLE_PERFORMANCE_MONITORING=true

# ────────────────────────────────────────────────────────────
# 日誌（Staging）
# ────────────────────────────────────────────────────────────

LOG_LEVEL=info
SENTRY_DSN=https://your-sentry-dsn@sentry.io/staging-project-id

# ────────────────────────────────────────────────────────────
# 部署設定
# ────────────────────────────────────────────────────────────

NEXT_PUBLIC_ENABLE_ISR=true
CDN_CACHE_TTL=3600
