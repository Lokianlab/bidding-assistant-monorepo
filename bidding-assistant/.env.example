# ============================================================
# 全能標案助理 — 環境變數範本
#
# 使用指南：
# 1. 複製此檔為 .env.local（本機開發）
# 2. 根據環境填入對應的值
# 3. .env.* 檔案請加入 .gitignore（禁止提交）
#
# 時間戳：2026-02-23
# ============================================================

# ────────────────────────────────────────────────────────────
# 應用程式基本設定
# ────────────────────────────────────────────────────────────

# 應用環境
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ────────────────────────────────────────────────────────────
# Supabase 資料庫配置（新增，支持知識庫 API）
# ────────────────────────────────────────────────────────────

# Supabase 連線設定
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_TENANT_ID=default-tenant-id

# 資料庫安全設定
DB_ENFORCE_RLS=true
DB_POOL_SIZE=10
DB_QUERY_TIMEOUT=5000

# ────────────────────────────────────────────────────────────
# NextAuth 認證配置
# ────────────────────────────────────────────────────────────

# NextAuth 密鑰（OpenSSL 生成：openssl rand -base64 32）
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Azure AD OAuth（選用）
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# ────────────────────────────────────────────────────────────
# 外部 API 配置
# ────────────────────────────────────────────────────────────

# Notion API（知識庫同步 — P1e Notion 同步引擎）
NOTION_TOKEN=
NOTION_DATABASE_ID=
NOTION_KB_DB_ID=

# Claude API（分析、搜尋）
ANTHROPIC_API_KEY=

# PCC 標案 API（政府採購公開資訊）
PCC_API_BASE_URL=https://api.pcc.gov.tw

# Google Drive / SmugMug（備用）
GOOGLE_CLIENT_ID_DRIVE=
GOOGLE_CLIENT_SECRET_DRIVE=
GOOGLE_REFRESH_TOKEN=
GOOGLE_SHARED_DRIVE_FOLDER_ID=

SMUGMUG_API_KEY=
SMUGMUG_API_SECRET=
SMUGMUG_ACCESS_TOKEN=
SMUGMUG_TOKEN_SECRET=
SMUGMUG_NICKNAME=

# ────────────────────────────────────────────────────────────
# 定時任務認證
# ────────────────────────────────────────────────────────────

# Cron 任務認證（P1e Notion 同步）
CRON_SECRET=

# ────────────────────────────────────────────────────────────
# 功能開關
# ────────────────────────────────────────────────────────────

DEBUG=false
NEXT_PUBLIC_USE_MOCK_DATA=false
NOTION_SYNC_INTERVAL=3600
ENABLE_PERFORMANCE_MONITORING=false

# ────────────────────────────────────────────────────────────
# 日誌和監控
# ────────────────────────────────────────────────────────────

LOG_LEVEL=info
SENTRY_DSN=

# ────────────────────────────────────────────────────────────
# 部署設定
# ────────────────────────────────────────────────────────────

NEXT_PUBLIC_ENABLE_ISR=true
CDN_CACHE_TTL=86400
