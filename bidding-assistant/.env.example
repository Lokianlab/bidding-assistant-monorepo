# 全能標案助理 — 環境變數範本
# 複製此檔為 .env.local 並填入實際值

# Notion API
NOTION_TOKEN=
NOTION_DATABASE_ID=

# Google Drive (OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_SHARED_DRIVE_FOLDER_ID=

# SmugMug (OAuth 1.0a)
SMUGMUG_API_KEY=
SMUGMUG_API_SECRET=
SMUGMUG_ACCESS_TOKEN=
SMUGMUG_TOKEN_SECRET=
SMUGMUG_NICKNAME=

# NextAuth (雲端部署時啟用)
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=http://localhost:3000
