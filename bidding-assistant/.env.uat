# 全能標案助理 — UAT 環境配置
#
# UAT 環境用途：
# - 用戶驗收測試
# - 接近生產的資料和配置
# - 使用複製的生產資料庫（sandbox）
# - 完整的監控和日誌
#
# 時間戳：2026-02-23

# ────────────────────────────────────────────────────────────
# 應用程式設定
# ────────────────────────────────────────────────────────────

NEXT_PUBLIC_APP_ENV=uat
NEXT_PUBLIC_APP_URL=https://uat.bidding-assistant.example.com
NODE_ENV=production

# ────────────────────────────────────────────────────────────
# Supabase 設定（UAT 環境，複製生產資料庫）
# ────────────────────────────────────────────────────────────

# ⚠️ 使用複製的生產資料庫（sandbox），具有相同結構和樣本資料
NEXT_PUBLIC_SUPABASE_URL=https://uat-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...uat...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...uat-secret...
NEXT_PUBLIC_TENANT_ID=uat-tenant

DB_ENFORCE_RLS=true
DB_POOL_SIZE=30
DB_QUERY_TIMEOUT=5000

# ────────────────────────────────────────────────────────────
# NextAuth 配置
# ────────────────────────────────────────────────────────────

NEXTAUTH_SECRET=your-uat-nextauth-secret-min-32-chars
NEXTAUTH_URL=https://uat.bidding-assistant.example.com

# Google OAuth + Azure AD（雙認證）
GOOGLE_CLIENT_ID=your-google-client-id-uat.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-secret-uat

AZURE_AD_CLIENT_ID=your-azure-client-id-uat
AZURE_AD_CLIENT_SECRET=your-azure-secret-uat
AZURE_AD_TENANT_ID=your-azure-tenant-id

# ────────────────────────────────────────────────────────────
# 外部 API（UAT）
# ────────────────────────────────────────────────────────────

NOTION_API_TOKEN=ntn_uat_token_here
NOTION_DATABASE_ID=uat-database-id

ANTHROPIC_API_KEY=sk-ant-uat-api-key
PCC_API_BASE_URL=https://api.pcc.gov.tw

# ────────────────────────────────────────────────────────────
# 功能開關（UAT：完整啟用）
# ────────────────────────────────────────────────────────────

DEBUG=false
NEXT_PUBLIC_USE_MOCK_DATA=false
NOTION_SYNC_INTERVAL=1800
ENABLE_PERFORMANCE_MONITORING=true

# ────────────────────────────────────────────────────────────
# 日誌和監控（UAT：完整）
# ────────────────────────────────────────────────────────────

LOG_LEVEL=info
SENTRY_DSN=https://your-sentry-dsn@sentry.io/uat-project-id

# ────────────────────────────────────────────────────────────
# 部署設定
# ────────────────────────────────────────────────────────────

NEXT_PUBLIC_ENABLE_ISR=true
CDN_CACHE_TTL=1800
